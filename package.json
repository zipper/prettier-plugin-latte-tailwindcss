{
  "name": "prettier-plugin-latte-tailwindcss",
  "version": "0.3.2",
  "description": "Prettier plugin for sorting Tailwind CSS v4 classes in Latte v3 templates",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "prettier",
    "prettier-plugin",
    "tailwindcss",
    "latte",
    "nette"
  ],
  "author": "Radek Šerý <radek.sery@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zipper/prettier-plugin-latte-tailwindcss.git"
  },
  "homepage": "https://github.com/zipper/prettier-plugin-latte-tailwindcss#readme",
  "bugs": {
    "url": "https://github.com/zipper/prettier-plugin-latte-tailwindcss/issues"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0",
    "@tailwindcss/node": ">=4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/node": "^4.0.0",
    "@types/node": "^20.0.0",
    "enhanced-resolve": "^5.15.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.19"
  }
}
